{
  "expo": {
    "name": "RunWise",
    "slug": "runwise",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "runwise",
    "userInterfaceStyle": "light",
    "android": {
      "package": "bw.co.runwise.app",
      "adaptiveIcon": {
        "backgroundColor": "#123F34"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "bw.co.runwise.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RunWise uses your location only during an active order to support a safe handover."
      }
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RunWise uses your location only during an active order to support a safe handover."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
